{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": "d4850ce6-5f90-4f38-8aac-94ad154048d2"
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngx-scanner-face": {
      "projectType": "library",
      "root": "projects/ngx-scanner-face",
      "sourceRoot": "projects/ngx-scanner-face/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/ngx-scanner-face/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ngx-scanner-face/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ngx-scanner-face/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/ngx-scanner-face/src/test.ts",
            "tsConfig": "projects/ngx-scanner-face/tsconfig.spec.json",
            "karmaConfig": "projects/ngx-scanner-face/karma.conf.js"
          }
        }
      }
    }
  },
  "defaultProject": "ngx-scanner-face"
}
