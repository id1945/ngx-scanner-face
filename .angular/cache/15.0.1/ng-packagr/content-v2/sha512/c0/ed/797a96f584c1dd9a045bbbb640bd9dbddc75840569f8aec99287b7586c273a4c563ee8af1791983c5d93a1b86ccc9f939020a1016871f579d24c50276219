53]],[[21,0,114,3]],[[17,0,115,1]]],"sourcesContent":["/**\n * @default ngx-scanner-face\n * @author <DaiDH>\n * @package https://www.npmjs.com/package/ngx-scanner-face\n * @license MIT https://github.com/id1945/ngx-scanner-face/blob/master/LICENSE\n * @copyright <https://github.com/id1945>\n*/\n\nimport { Component, ElementRef, EventEmitter, OnDestroy, OnInit, ViewChild } from '@angular/core';\nimport { AsyncSubject, BehaviorSubject } from 'rxjs';\nimport Human, { Config, DrawOptions, Env, Result } from '@vladmandic/human';\n\nexport interface UnknownObject {\n  [key: string]: any;\n}\n\nexport interface BaseConfig {\n  src?: string;\n  isAuto?: boolean;\n  isLoading?: boolean;\n  fps?: number;\n  env?: Partial<Env>;\n  draw?: Partial<DrawOptions>;\n  human?: Partial<Config>;\n  style?: UnknownObject;\n  medias?: UnknownObject;\n};\n\n/**\n * user configuration for human, used to fine-tune behavior\n */\nconst H_CONFIG: Partial<Config> = {\n  async: false,\n  modelBasePath: './models',\n  filter: {\n    flip: false,\n    enabled: true,\n    equalization: false,\n  },\n  face: {\n    enabled: true,\n    detector: {\n      rotation: false\n    },\n    mesh: {\n      enabled: true\n    },\n    attention: {\n      enabled: false\n    },\n    iris: {\n      enabled: true\n    },\n    description: {\n      enabled: true\n    },\n    emotion: {\n      enabled: true\n    }\n  },\n  body: { enabled: true },\n  hand: { enabled: true },\n  object: { enabled: false },\n  gesture: { enabled: true },\n};\n\n/**\n * Env class that holds detected capabilities\n */\nconst H_ENV: Partial<Env> = {\n  perfadd: false // is performance data showing instant or total values\n}\n\n/** \n * Draw Options\n */\nconst H_DRAW_OPTIONS: Partial<DrawOptions> = {\n  font: 'monospace', // set font used to draw labels when using draw methods\n  lineHeight: 20\n}\n\n/**\n * MediaStream\n * Use facingMode: environment to attemt to get the front camera on phones\n * { facingMode: 'user', width: { ideal: document.body.clientWidth }, height: { ideal: document.body.clientHeight }\n */\nconst MEDIASTREAM: MediaStreamConstraints = {\n  audio: false,\n  video: {\n    width: { ideal: 1280 },\n    height: { ideal: 720 },\n    facingMode: 'environment' // To require the rear camera https://developer.mozilla.org/en-US/docs/Web/API/MediaDevices/getUserMedia\n  }\n}\n\n/**\n * Style for HTMLCanvasElement\n */\nconst STYLE: UnknownObject = {\n  width: '100%',\n  height: '100%',\n  background: '#000000'\n}\n\n@Component({\n  selector: 'ngx-scanner-face',\n  template: `<canvas #canvas [style]=\"style\"></canvas><video #video playsinline style=\"display: none\"></video><ng-content></ng-content>`,\n  host: { 'class': 'ngx-scanner-face' },\n  inputs: ['src', 'isAuto', 'fps', 'style', 'medias', 'env', 'draw', 'human', 'config'],\n  outputs: ['event', 'error'],\n  exportAs: 'scanner',\n  queries: {\n    video: new ViewChild('video', { static: true }),\n    canvas: new ViewChild('canvas', { static: true })\n  }\n})\nexport class NgxScannerFaceComponent implements OnInit, OnDestroy {\n\n  /**\n   * Element\n   * playsinline required to tell iOS safari we don't want fullscreen\n   */\n  public video!: ElementRef;\n  public canvas!: ElementRef;\n\n  /**\n   * EventEmitter\n   */\n  public event = new EventEmitter<Partial<Result>>();\n  public error = new EventEmitter<any>();\n\n  /**\n   * Input\n   */\n  public src: string = '';\n  public isAuto: boolean = false; // Auto start camera.\n  public fps: number = 30; // Frame speed ms/fps.\n  public style: UnknownObject = {};\n  public medias: MediaStreamConstraints = {};\n  public env: Partial<Env> = {};\n  public draw: Partial<DrawOptions> = {};\n  public human: Partial<Config> = {};\n  public config: BaseConfig = {};\n\n  /**\n   * Export\n   */\n  public isStart: boolean = false;\n  public isLoading: boolean = false;\n  public data = new BehaviorSubject<Partial<Result>>({});\n\n  ngOnInit(): void {\n    this.overrideConfig();\n    if (this.src) {\n      this.loadImage(this.src);\n    } else if (this.isAuto) {\n      this.start();\n    }\n  }\n\n  /**\n   * start\n   * @return AsyncSubject\n   */\n  public start(): AsyncSubject<any> {\n    const as = new AsyncSubject<any>();\n    if (this.isStart) {\n      // Reject\n      this.complete(as, false);\n    } else {\n      const run = async () => {\n        try {\n          // Loading on\n          this.status(false, true);\n\n          // new Human\n          let human = new Human(this.human); // create instance of human with overrides from user configuration\n          this.overrideEnv(human);\n          this.overrideDraw(human);\n\n          // grab instances of dom objects so we dont have to look them up later\n          const dom = {\n            video: this.video.nativeElement as HTMLVideoElement,\n            canvas: this.canvas.nativeElement as HTMLCanvasElement\n          };\n\n          const timestamp = { detect: 0, draw: 0, tensors: 0, start: 0 }; // holds information used to calculate performance and possible memory leaks\n          const fps = { detectFPS: 0, drawFPS: 0, frames: 0, averageMs: 0 }; // holds calculated fps information for both detect and screen refresh\n          const webCam = async () => { // initialize webcam\n            const stream: MediaStream = await navigator.mediaDevices.getUserMedia(this.medias);\n            const ready = new Promise((resolve) => { dom.video.onloadeddata = () => resolve(true); });\n            dom.video.srcObject = stream;\n            void dom.video.play();\n            await ready;\n            dom.canvas.width = dom.video.videoWidth;\n            dom.canvas.height = dom.video.videoHeight;\n            dom.canvas.onclick = () => dom.video.paused ? this.play() : this.pause(); // pause when clicked on screen and resume on next click\n          }\n\n          const detectionLoop = async () => { // main detection loop\n            if (!dom.video.paused) {\n              if (timestamp.start === 0) t